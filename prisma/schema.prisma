generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// ========================
// AUTH
// ========================
model Usuario {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  senhaHash    String    @map("senha_hash")
  papel        Papel     @default(MEMBRO)
  ativo        Boolean   @default(true)
  criadoEm     DateTime  @default(now()) @map("criado_em")
  ultimoAcesso DateTime? @map("ultimo_acesso")

  membro       Membro?

  avisosAutor        Aviso[]
  eventosAutor       Evento[]
  lancamentosAutor   LancamentoFinanceiro[]

  @@map("usuarios")
}

enum Papel {
  PASTOR
  LIDER
  TESOUREIRO
  MEMBRO
}

// ========================
// MEMBROS
// ========================
model Membro {
  id            Int           @id @default(autoincrement())
  nome          String
  cpf           String?       @unique
  telefone      String?
  email         String?       @unique
  dataNascimento DateTime?    @map("data_nascimento")
  estadoCivil   EstadoCivil?  @map("estado_civil")
  endereco      String?
  fotoUrl       String?       @map("foto_url")
  dataIngresso  DateTime      @default(now()) @map("data_ingresso")
  status        StatusMembro  @default(ATIVO)
  criadoEm      DateTime      @default(now()) @map("criado_em")

  usuarioId     Int?          @unique @map("usuario_id")
  usuario       Usuario?      @relation(fields: [usuarioId], references: [id])

  grupos            GrupoMembro[]
  frequencias       Frequencia[]
  lancamentos       LancamentoFinanceiro[]
  eventosConfirmados EventoConfirmacao[]
  pedidosOracao     PedidoOracao[]
  oracoes           Oracao[]
  gruposLiderados   Grupo[]

  @@map("membros")
}

enum EstadoCivil {
  SOLTEIRO
  CASADO
  DIVORCIADO
  VIUVO
}

enum StatusMembro {
  ATIVO
  INATIVO
}

model Grupo {
  id          Int      @id @default(autoincrement())
  nome        String
  descricao   String?
  criadoEm   DateTime  @default(now()) @map("criado_em")

  liderId     Int      @map("lider_id")
  lider       Membro   @relation(fields: [liderId], references: [id])

  membros     GrupoMembro[]
  avisos      Aviso[]

  @@map("grupos")
}

model GrupoMembro {
  grupoId   Int @map("grupo_id")
  membroId  Int @map("membro_id")

  grupo   Grupo  @relation(fields: [grupoId], references: [id])
  membro  Membro @relation(fields: [membroId], references: [id])

  @@id([grupoId, membroId])
  @@map("grupo_membros")
}

model Frequencia {
  id           Int      @id @default(autoincrement())
  presente     Boolean  @default(true)
  registradoEm DateTime @default(now()) @map("registrado_em")

  membroId  Int    @map("membro_id")
  eventoId  Int    @map("evento_id")
  membro    Membro @relation(fields: [membroId], references: [id])
  evento    Evento @relation(fields: [eventoId], references: [id])

  @@map("frequencias")
}

// ========================
// FINANCEIRO
// ========================
model CategoriaFinanceira {
  id        Int    @id @default(autoincrement())
  nome      String
  tipo      TipoLancamento

  lancamentos LancamentoFinanceiro[]

  @@map("categorias_financeiras")
}

enum TipoLancamento {
  DIZIMO
  DOACAO
  DESPESA
}

model Campanha {
  id          Int       @id @default(autoincrement())
  nome        String
  descricao   String?
  metaValor   Decimal?  @map("meta_valor") @db.Decimal(10, 2)
  dataInicio  DateTime  @map("data_inicio")
  dataFim     DateTime? @map("data_fim")

  lancamentos LancamentoFinanceiro[]

  @@map("campanhas")
}

model LancamentoFinanceiro {
  id             Int            @id @default(autoincrement())
  tipo           TipoLancamento
  valor          Decimal        @db.Decimal(10, 2)
  data           DateTime
  descricao      String?
  comprovanteUrl String?        @map("comprovante_url")
  criadoEm      DateTime        @default(now()) @map("criado_em")

  membroId      Int?   @map("membro_id")
  campanhaId    Int?   @map("campanha_id")
  categoriaId   Int    @map("categoria_id")
  registradoPor Int    @map("registrado_por")

  membro    Membro?             @relation(fields: [membroId], references: [id])
  campanha  Campanha?           @relation(fields: [campanhaId], references: [id])
  categoria CategoriaFinanceira @relation(fields: [categoriaId], references: [id])
  usuario   Usuario             @relation(fields: [registradoPor], references: [id])

  @@map("lancamentos_financeiros")
}

// ========================
// COMUNICAÇÃO INTERNA
// ========================
model Aviso {
  id          Int      @id @default(autoincrement())
  titulo      String
  conteudo    String   @db.Text
  publicadoEm DateTime @default(now()) @map("publicado_em")
  ativo       Boolean  @default(true)

  autorId  Int   @map("autor_id")
  grupoId  Int?  @map("grupo_id")

  autor  Usuario @relation(fields: [autorId], references: [id])
  grupo  Grupo?  @relation(fields: [grupoId], references: [id])

  @@map("avisos")
}

model Evento {
  id          Int       @id @default(autoincrement())
  titulo      String
  descricao   String?   @db.Text
  local       String?
  dataInicio  DateTime  @map("data_inicio")
  dataFim     DateTime? @map("data_fim")
  cancelado   Boolean   @default(false)
  criadoEm   DateTime   @default(now()) @map("criado_em")

  criadoPor Int @map("criado_por")
  autor     Usuario @relation(fields: [criadoPor], references: [id])

  confirmacoes EventoConfirmacao[]
  frequencias  Frequencia[]

  @@map("eventos")
}

model EventoConfirmacao {
  eventoId  Int @map("evento_id")
  membroId  Int @map("membro_id")

  evento  Evento @relation(fields: [eventoId], references: [id])
  membro  Membro @relation(fields: [membroId], references: [id])

  @@id([eventoId, membroId])
  @@map("evento_confirmacoes")
}

model PedidoOracao {
  id        Int      @id @default(autoincrement())
  conteudo  String   @db.Text
  privado   Boolean  @default(false)
  respondido Boolean @default(false)
  criadoEm  DateTime @default(now()) @map("criado_em")

  membroId Int    @map("membro_id")
  membro   Membro @relation(fields: [membroId], references: [id])

  oracoes Oracao[]

  @@map("pedidos_oracao")
}

model Oracao {
  pedidoId Int @map("pedido_id")
  membroId Int @map("membro_id")

  pedido PedidoOracao @relation(fields: [pedidoId], references: [id])
  membro Membro       @relation(fields: [membroId], references: [id])

  @@id([pedidoId, membroId])
  @@map("oracoes")
}
